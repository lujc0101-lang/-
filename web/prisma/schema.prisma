generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  LEADER
  ADMIN
}

enum ClubStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
}

enum ApplicationStatus {
  SUBMITTED
  CONTACTED
  INTERVIEW
  ACCEPTED
  WAITLIST
  REJECTED
}

enum PostType {
  RECRUIT
  ACTIVITY
  DISCUSS
}

enum PostStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id                       String    @id @default(cuid())
  email                    String    @unique
  passwordHash             String
  role                     Role
  name                     String
  studentId                String?
  notifyDeadlineReminders  Boolean   @default(true)
  profile                  String?   // JSON
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  clubsLed          Club[]           @relation("ClubLeader")
  applications      Application[]
  matchProfile      MatchProfile?
  favorites         Favorite[]
  notifications     Notification[]
  inviteCodesUsed   InviteCode[]     @relation("InviteUsedBy")
  posts             Post[]
  postLikes         PostLike[]
  postFavorites     PostFavorite[]
  postComments      PostComment[]
}

model InviteCode {
  id           String    @id @default(cuid())
  code         String    @unique
  clubId       String?
  club         Club?     @relation(fields: [clubId], references: [id], onDelete: SetNull)
  expiresAt    DateTime?
  consumedAt   DateTime?
  usedByUserId String?
  usedBy       User?     @relation("InviteUsedBy", fields: [usedByUserId], references: [id])
  createdAt    DateTime  @default(now())
}

model Club {
  id                String      @id @default(cuid())
  name              String      @unique
  slogan            String
  category          String
  tags              String      // JSON string[]
  description       String
  coverUrl          String?
  gallery           String?     // JSON string[]
  activityTypes     String      // JSON string[]
  intensity         String      // light | medium | heavy
  beginnerFriendly  Boolean     @default(false)
  recruitStart      DateTime
  recruitEnd        DateTime
  recruitQuotaNote  String?
  applyNote         String?
  contact           String?     // JSON
  customForm        String?     // JSON CustomFormField[]
  leaderDisplayName String
  leaderUserId      String?
  leader            User?       @relation("ClubLeader", fields: [leaderUserId], references: [id])
  status            ClubStatus  @default(DRAFT)
  seasonId          String      @default("2025-FALL")
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  applications Application[]
  favorites    Favorite[]
  inviteCodes  InviteCode[]
  posts        Post[]
}

model Post {
  id         String     @id @default(cuid())
  authorId   String
  author     User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  type       PostType
  title      String?
  content    String
  images     String     @default("[]") // JSON string[] URLs
  clubId     String?
  club       Club?      @relation(fields: [clubId], references: [id], onDelete: SetNull)
  tags       String     @default("[]") // JSON string[] 话题，不含 #
  status     PostStatus @default(PENDING)
  pinned     Boolean    @default(false)
  rejectNote String?
  reviewedAt DateTime?
  reviewerId String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  likes     PostLike[]
  favs      PostFavorite[]
  comments  PostComment[]

  @@index([status, pinned, createdAt])
  @@index([clubId])
  @@index([type, status])
}

model PostLike {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId])
}

model PostFavorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId])
}

model PostComment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@index([postId, createdAt])
}

model Application {
  id             String             @id @default(cuid())
  userId         String
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  clubId         String
  club           Club               @relation(fields: [clubId], references: [id], onDelete: Cascade)
  seasonId       String
  commonAnswers  String             // JSON
  customAnswers  String             // JSON
  status         ApplicationStatus  @default(SUBMITTED)
  clubSnapshot   String?            // JSON
  timeline       String             // JSON TimelineEvent[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([userId, clubId, seasonId])
  @@index([clubId, status])
}

model MatchProfile {
  userId    String   @id
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers   String   // JSON MatchAnswers
  nlSource  String?
  updatedAt DateTime @updatedAt
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clubId    String
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, clubId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  payload   String    // JSON { href, title, body }
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  type      String
  clubId    String?
  userId    String?
  sessionId String
  meta      String?  // JSON
  ts        DateTime @default(now())

  @@index([type, ts])
  @@index([clubId, ts])
}
